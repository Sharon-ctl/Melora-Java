# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: YouTube PoToken and VisitorData (to bypass VPS 403 "Video requires login" errors)
# Use a browser extension or devtools to extract these from a logged-in YouTube session
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=
